# Qwen Cloud API key (from home.qwencloud.com/api-keys)
QWEN_API_KEY=sk-your-key-here

# OpenAI-compatible endpoint (international / Singapore region)
QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1

# Model used for Game Master narration (quality)
QWEN_GM_MODEL=qwen-plus

# Cheaper/faster model for memory operations (extraction, scoring, summaries)
QWEN_MEMORY_MODEL=qwen-flash

# Embedding model used to index episodic memories
QWEN_EMBED_MODEL=text-embedding-v3
QWEN_EMBED_DIM=1024

# Postgres + pgvector (matches docker-compose.yml defaults)
POSTGRES_HOST=localhost
POSTGRES_PORT=5544
POSTGRES_DB=loremaster
POSTGRES_USER=loremaster
POSTGRES_PASSWORD=loremaster
